<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Community Dynamics Explorer — Chapter 18</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Cinzel:wght@600;700;900&family=Crimson+Pro:ital,wght@0,400;0,600;1,400&family=Source+Code+Pro:wght@400;600&display=swap" rel="stylesheet">
<style>
/* ── DESIGN TOKENS ────────────────────────────── */
:root {
  --forest-black:   #080c07;
  --forest-deep:    #0d1510;
  --forest-dark:    #111d0f;
  --forest-mid:     #1a2e16;
  --forest-bark:    #2a3d22;
  --canopy:         #3a5c2a;
  --moss:           #5a8040;
  --fern:           #7db356;
  --lichen:         #a8cc78;
  --biolume:        #b8ff6a;
  --biolume-glow:   rgba(184,255,106,0.25);
  --amber:          #e8a740;
  --ember:          #f04f30;
  --mist:           rgba(168,204,120,0.07);
  --text-primary:   #e8f0d8;
  --text-secondary: #9fb885;
  --text-muted:     #5a7048;
  --border-subtle:  rgba(90,128,64,0.25);
  --border-glow:    rgba(184,255,106,0.4);
  --correct-bg:     rgba(90,195,80,0.15);
  --correct-border: #5ac350;
  --wrong-bg:       rgba(240,79,48,0.15);
  --wrong-border:   #f04f30;
  --focus-ring:     #b8ff6a;
  --shadow-deep:    0 8px 40px rgba(0,0,0,0.7);
}

/* ── RESET & BASE ─────────────────────────────── */
*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

html { scroll-behavior: smooth; }

body {
  background: var(--forest-black);
  color: var(--text-primary);
  font-family: 'Crimson Pro', Georgia, serif;
  font-size: 1.1rem;
  line-height: 1.7;
  min-height: 100vh;
  overflow-x: hidden;
}

/* ── SKIP LINK (ADA) ─────────────────────────── */
.skip-link {
  position: absolute;
  top: -100%;
  left: 1rem;
  background: var(--biolume);
  color: var(--forest-black);
  font-family: 'Source Code Pro', monospace;
  font-size: 0.85rem;
  font-weight: 600;
  padding: 0.5rem 1rem;
  border-radius: 4px;
  z-index: 9999;
  text-decoration: none;
  transition: top 0.2s;
}
.skip-link:focus { top: 1rem; }

/* ── FOCUS STYLES (ADA) ──────────────────────── */
:focus-visible {
  outline: 3px solid var(--focus-ring);
  outline-offset: 3px;
  border-radius: 4px;
}

/* ── ANIMATED FOREST BACKGROUND ─────────────── */
.forest-bg {
  position: fixed;
  inset: 0;
  pointer-events: none;
  z-index: 0;
  overflow: hidden;
}

.forest-bg::before {
  content: '';
  position: absolute;
  inset: 0;
  background:
    radial-gradient(ellipse 80% 60% at 50% 100%, rgba(26,46,22,0.9) 0%, transparent 70%),
    radial-gradient(ellipse 40% 40% at 20% 80%, rgba(58,92,42,0.3) 0%, transparent 60%),
    radial-gradient(ellipse 40% 40% at 80% 85%, rgba(42,61,34,0.4) 0%, transparent 60%),
    radial-gradient(ellipse 100% 50% at 50% 110%, rgba(17,29,15,1) 0%, transparent 80%);
}

/* SVG tree silhouettes */
.tree-layer {
  position: absolute;
  bottom: 0;
  width: 100%;
  height: 55%;
}

/* Floating spores / particles */
.spore {
  position: absolute;
  border-radius: 50%;
  background: var(--biolume);
  opacity: 0;
  animation: float-spore linear infinite;
  pointer-events: none;
}

@keyframes float-spore {
  0%   { transform: translateY(0) translateX(0) scale(1); opacity: 0; }
  15%  { opacity: 0.6; }
  85%  { opacity: 0.3; }
  100% { transform: translateY(-120vh) translateX(var(--drift)) scale(0.3); opacity: 0; }
}

/* Mist layers */
.mist-band {
  position: absolute;
  left: -20%;
  width: 140%;
  height: 80px;
  background: linear-gradient(90deg, transparent, rgba(120,170,80,0.05), rgba(100,150,60,0.08), transparent);
  animation: drift-mist linear infinite;
  border-radius: 50%;
}

@keyframes drift-mist {
  from { transform: translateX(-10%); }
  to   { transform: translateX(10%); }
}

/* ── LAYOUT WRAPPER ──────────────────────────── */
.app {
  position: relative;
  z-index: 1;
  max-width: 820px;
  margin: 0 auto;
  padding: 2rem 1.25rem 4rem;
  min-height: 100vh;
}

/* ── SCREENS ─────────────────────────────────── */
.screen { display: none; }
.screen.active { display: block; }

/* ── TITLE SCREEN ────────────────────────────── */
#title-screen { text-align: center; padding-top: 3rem; }

.chapter-tag {
  display: inline-block;
  font-family: 'Source Code Pro', monospace;
  font-size: 0.72rem;
  letter-spacing: 4px;
  text-transform: uppercase;
  color: var(--moss);
  border: 1px solid var(--forest-bark);
  padding: 0.3rem 1.2rem;
  border-radius: 2px;
  margin-bottom: 1.5rem;
}

.title-emblem {
  font-size: 4rem;
  margin-bottom: 0.5rem;
  filter: drop-shadow(0 0 20px rgba(184,255,106,0.4));
  animation: breathe 4s ease-in-out infinite;
}

@keyframes breathe {
  0%, 100% { filter: drop-shadow(0 0 20px rgba(184,255,106,0.4)); }
  50%       { filter: drop-shadow(0 0 40px rgba(184,255,106,0.7)); }
}

h1.game-title {
  font-family: 'Cinzel', serif;
  font-size: clamp(2rem, 6vw, 3.6rem);
  font-weight: 900;
  color: var(--text-primary);
  line-height: 1.1;
  text-shadow: 0 0 40px rgba(184,255,106,0.3), 0 2px 8px rgba(0,0,0,0.8);
  margin-bottom: 0.4rem;
}

h1.game-title em {
  color: var(--biolume);
  font-style: normal;
  text-shadow: 0 0 20px rgba(184,255,106,0.7);
}

.title-sub {
  font-family: 'Cinzel', serif;
  font-size: clamp(0.8rem, 2vw, 1rem);
  letter-spacing: 3px;
  color: var(--text-secondary);
  margin-bottom: 2.5rem;
}

.title-description {
  max-width: 520px;
  margin: 0 auto 2.5rem;
  color: var(--text-secondary);
  font-size: 1rem;
  line-height: 1.8;
  font-style: italic;
}

/* Difficulty selector */
.difficulty-label {
  font-family: 'Source Code Pro', monospace;
  font-size: 0.7rem;
  letter-spacing: 3px;
  text-transform: uppercase;
  color: var(--text-muted);
  margin-bottom: 0.75rem;
}

.difficulty-row {
  display: flex;
  gap: 0.75rem;
  justify-content: center;
  flex-wrap: wrap;
  margin-bottom: 2.5rem;
}

.diff-btn {
  font-family: 'Source Code Pro', monospace;
  font-size: 0.78rem;
  letter-spacing: 2px;
  text-transform: uppercase;
  color: var(--text-secondary);
  background: var(--forest-dark);
  border: 1px solid var(--border-subtle);
  padding: 0.6rem 1.4rem;
  border-radius: 3px;
  cursor: pointer;
  transition: all 0.2s;
}

.diff-btn:hover {
  border-color: var(--moss);
  color: var(--lichen);
  background: var(--forest-mid);
}

.diff-btn[aria-pressed="true"], .diff-btn.selected {
  border-color: var(--biolume);
  color: var(--forest-black);
  background: var(--biolume);
  box-shadow: 0 0 16px rgba(184,255,106,0.4);
}

.btn-start {
  font-family: 'Cinzel', serif;
  font-size: 1rem;
  font-weight: 700;
  letter-spacing: 3px;
  text-transform: uppercase;
  color: var(--forest-black);
  background: var(--biolume);
  border: none;
  padding: 1rem 3.5rem;
  border-radius: 4px;
  cursor: pointer;
  transition: all 0.25s;
  box-shadow: 0 0 24px rgba(184,255,106,0.4), var(--shadow-deep);
  display: inline-flex;
  align-items: center;
  gap: 0.5rem;
}

.btn-start:hover {
  background: #d4ff60;
  box-shadow: 0 0 40px rgba(184,255,106,0.7), var(--shadow-deep);
  transform: translateY(-2px);
}

.title-stats {
  margin-top: 2rem;
  font-family: 'Source Code Pro', monospace;
  font-size: 0.72rem;
  color: var(--text-muted);
  letter-spacing: 2px;
}

/* ── QUIZ SCREEN ─────────────────────────────── */
#quiz-screen { padding-top: 1.5rem; }

/* HUD Bar */
.hud {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 1rem;
  margin-bottom: 2rem;
  flex-wrap: wrap;
}

.hud-score {
  font-family: 'Cinzel', serif;
  font-size: 1.1rem;
  color: var(--amber);
}

.hud-score span {
  font-size: 1.6rem;
  font-weight: 700;
  text-shadow: 0 0 12px rgba(232,167,64,0.5);
}

.hud-progress { flex: 1; min-width: 140px; }

.progress-label {
  display: flex;
  justify-content: space-between;
  font-family: 'Source Code Pro', monospace;
  font-size: 0.7rem;
  color: var(--text-muted);
  margin-bottom: 0.35rem;
  letter-spacing: 1px;
}

.progress-track {
  height: 6px;
  background: var(--forest-mid);
  border-radius: 3px;
  overflow: hidden;
  border: 1px solid var(--border-subtle);
}

.progress-fill {
  height: 100%;
  background: linear-gradient(90deg, var(--canopy), var(--biolume));
  border-radius: 3px;
  transition: width 0.6s cubic-bezier(0.4,0,0.2,1);
  box-shadow: 0 0 8px rgba(184,255,106,0.4);
}

.hud-lives {
  font-size: 1.1rem;
  letter-spacing: 3px;
  min-width: 80px;
  text-align: right;
}

/* Question card */
.q-card {
  background: linear-gradient(145deg, var(--forest-deep), var(--forest-dark));
  border: 1px solid var(--border-subtle);
  border-radius: 10px;
  padding: 2rem 2.2rem;
  margin-bottom: 1.5rem;
  box-shadow: var(--shadow-deep), inset 0 1px 0 rgba(184,255,106,0.05);
  position: relative;
  overflow: hidden;
  animation: card-in 0.4s ease both;
}

@keyframes card-in {
  from { opacity: 0; transform: translateY(16px); }
  to   { opacity: 1; transform: translateY(0); }
}

.q-card::before {
  content: '';
  position: absolute;
  top: 0; left: 0; right: 0;
  height: 2px;
  background: linear-gradient(90deg, transparent, var(--canopy), var(--biolume), var(--canopy), transparent);
  opacity: 0.6;
}

.q-meta {
  display: flex;
  align-items: center;
  gap: 0.75rem;
  margin-bottom: 1.2rem;
  flex-wrap: wrap;
}

.q-num {
  font-family: 'Source Code Pro', monospace;
  font-size: 0.7rem;
  letter-spacing: 3px;
  color: var(--text-muted);
  text-transform: uppercase;
}

.q-topic {
  font-family: 'Source Code Pro', monospace;
  font-size: 0.68rem;
  letter-spacing: 2px;
  color: var(--moss);
  background: rgba(90,128,64,0.15);
  border: 1px solid rgba(90,128,64,0.3);
  padding: 0.15rem 0.6rem;
  border-radius: 2px;
  text-transform: uppercase;
}

.q-text {
  font-size: 1.2rem;
  line-height: 1.75;
  color: var(--text-primary);
  font-weight: 400;
}

/* Answer choices */
.choices {
  display: flex;
  flex-direction: column;
  gap: 0.65rem;
  margin-bottom: 1.5rem;
}

.choice-btn {
  display: flex;
  align-items: flex-start;
  gap: 1rem;
  background: var(--forest-dark);
  border: 1px solid var(--border-subtle);
  border-radius: 8px;
  padding: 0.9rem 1.2rem;
  cursor: pointer;
  text-align: left;
  font-family: 'Crimson Pro', serif;
  font-size: 1.05rem;
  color: var(--text-primary);
  line-height: 1.5;
  transition: all 0.18s;
  width: 100%;
  position: relative;
  overflow: hidden;
}

.choice-btn::before {
  content: '';
  position: absolute;
  inset: 0;
  background: linear-gradient(135deg, rgba(184,255,106,0.04), transparent);
  opacity: 0;
  transition: opacity 0.18s;
}

.choice-btn:hover:not(:disabled)::before { opacity: 1; }

.choice-btn:hover:not(:disabled) {
  border-color: var(--moss);
  background: var(--forest-mid);
  transform: translateX(4px);
}

.choice-letter {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 28px;
  height: 28px;
  min-width: 28px;
  border-radius: 50%;
  background: var(--forest-bark);
  border: 1px solid var(--border-subtle);
  font-family: 'Cinzel', serif;
  font-size: 0.75rem;
  font-weight: 700;
  color: var(--text-secondary);
  transition: all 0.18s;
  flex-shrink: 0;
  margin-top: 1px;
}

.choice-btn:hover:not(:disabled) .choice-letter {
  background: var(--canopy);
  border-color: var(--moss);
  color: var(--lichen);
}

/* Keyboard shortcut hint */
.choice-key-hint {
  position: absolute;
  right: 1rem;
  top: 50%;
  transform: translateY(-50%);
  font-family: 'Source Code Pro', monospace;
  font-size: 0.65rem;
  color: var(--text-muted);
  border: 1px solid var(--forest-bark);
  padding: 0.1rem 0.4rem;
  border-radius: 3px;
  opacity: 0;
  transition: opacity 0.2s;
}

.choice-btn:focus-visible .choice-key-hint,
.choice-btn:hover:not(:disabled) .choice-key-hint { opacity: 0.7; }

/* Answer states */
.choice-btn.correct {
  background: var(--correct-bg);
  border-color: var(--correct-border);
  color: #a0f088;
}

.choice-btn.correct .choice-letter {
  background: var(--correct-border);
  border-color: var(--correct-border);
  color: var(--forest-black);
}

.choice-btn.wrong {
  background: var(--wrong-bg);
  border-color: var(--wrong-border);
  color: #f09080;
}

.choice-btn.wrong .choice-letter {
  background: var(--wrong-border);
  border-color: var(--wrong-border);
  color: #fff;
}

.choice-btn:disabled { cursor: default; }

/* Feedback panel */
.feedback-panel {
  border-radius: 8px;
  padding: 1rem 1.3rem;
  margin-bottom: 1.2rem;
  font-size: 1rem;
  line-height: 1.7;
  display: none;
  animation: fade-in 0.3s ease;
}

@keyframes fade-in {
  from { opacity: 0; transform: translateY(-6px); }
  to   { opacity: 1; transform: translateY(0); }
}

.feedback-panel.correct {
  display: block;
  background: var(--correct-bg);
  border: 1px solid rgba(90,195,80,0.3);
  color: #a8f090;
}

.feedback-panel.wrong {
  display: block;
  background: var(--wrong-bg);
  border: 1px solid rgba(240,79,48,0.3);
  color: #f0a090;
}

.feedback-icon { font-size: 1.1rem; margin-right: 0.4rem; }

/* Next button */
.btn-next {
  font-family: 'Cinzel', serif;
  font-size: 0.9rem;
  font-weight: 700;
  letter-spacing: 3px;
  text-transform: uppercase;
  color: var(--forest-black);
  background: var(--fern);
  border: none;
  padding: 0.85rem 2.5rem;
  border-radius: 4px;
  cursor: pointer;
  transition: all 0.2s;
  display: none;
  box-shadow: 0 0 16px rgba(125,179,86,0.3);
}

.btn-next:hover {
  background: var(--lichen);
  box-shadow: 0 0 24px rgba(168,204,120,0.5);
  transform: translateY(-1px);
}

/* Keyboard hint bar */
.key-hint-bar {
  text-align: center;
  font-family: 'Source Code Pro', monospace;
  font-size: 0.67rem;
  color: var(--text-muted);
  letter-spacing: 2px;
  margin-top: 1.5rem;
  padding-top: 1rem;
  border-top: 1px solid var(--border-subtle);
}

.key-tag {
  display: inline-block;
  background: var(--forest-bark);
  border: 1px solid var(--border-subtle);
  padding: 0.1rem 0.45rem;
  border-radius: 3px;
  font-size: 0.7rem;
  margin: 0 2px;
}

/* ── RESULTS SCREEN ──────────────────────────── */
#result-screen {
  text-align: center;
  padding-top: 2.5rem;
}

.result-emblem {
  font-size: 4rem;
  margin-bottom: 0.75rem;
  animation: breathe 3s ease-in-out infinite;
}

.result-heading {
  font-family: 'Cinzel', serif;
  font-size: clamp(1.8rem, 5vw, 2.8rem);
  font-weight: 900;
  margin-bottom: 0.4rem;
  text-shadow: 0 0 30px currentColor;
}

.result-heading.excellent { color: var(--biolume); }
.result-heading.great     { color: var(--lichen); }
.result-heading.good      { color: var(--amber); }
.result-heading.study     { color: var(--ember); }

.result-big-score {
  font-family: 'Cinzel', serif;
  font-size: clamp(3rem, 10vw, 5.5rem);
  font-weight: 900;
  color: var(--text-primary);
  text-shadow: 0 0 40px rgba(184,255,106,0.4);
  line-height: 1;
  margin-bottom: 0.2rem;
}

.result-score-label {
  font-family: 'Source Code Pro', monospace;
  font-size: 0.72rem;
  letter-spacing: 4px;
  color: var(--text-muted);
  text-transform: uppercase;
  margin-bottom: 2rem;
}

/* Stat grid */
.stat-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 1rem;
  max-width: 480px;
  margin: 0 auto 2rem;
}

.stat-card {
  background: var(--forest-dark);
  border: 1px solid var(--border-subtle);
  border-radius: 8px;
  padding: 1.1rem 0.5rem;
}

.stat-val {
  font-family: 'Cinzel', serif;
  font-size: 2rem;
  font-weight: 700;
  display: block;
  line-height: 1;
  margin-bottom: 0.3rem;
}

.stat-val.green { color: var(--fern); }
.stat-val.red   { color: var(--ember); }
.stat-val.blue  { color: var(--lichen); }

.stat-lbl {
  font-family: 'Source Code Pro', monospace;
  font-size: 0.65rem;
  letter-spacing: 2px;
  color: var(--text-muted);
  text-transform: uppercase;
}

.result-message {
  max-width: 500px;
  margin: 0 auto 2.5rem;
  color: var(--text-secondary);
  font-size: 1rem;
  line-height: 1.8;
  font-style: italic;
}

.result-actions {
  display: flex;
  gap: 1rem;
  justify-content: center;
  flex-wrap: wrap;
}

.btn-replay {
  font-family: 'Cinzel', serif;
  font-size: 0.9rem;
  font-weight: 700;
  letter-spacing: 3px;
  text-transform: uppercase;
  color: var(--forest-black);
  background: var(--biolume);
  border: none;
  padding: 0.9rem 2.5rem;
  border-radius: 4px;
  cursor: pointer;
  transition: all 0.2s;
  box-shadow: 0 0 20px rgba(184,255,106,0.35);
}

.btn-replay:hover {
  background: #d4ff60;
  box-shadow: 0 0 36px rgba(184,255,106,0.6);
  transform: translateY(-2px);
}

.btn-menu {
  font-family: 'Cinzel', serif;
  font-size: 0.9rem;
  font-weight: 700;
  letter-spacing: 3px;
  text-transform: uppercase;
  color: var(--lichen);
  background: transparent;
  border: 1px solid var(--canopy);
  padding: 0.9rem 2.5rem;
  border-radius: 4px;
  cursor: pointer;
  transition: all 0.2s;
}

.btn-menu:hover {
  border-color: var(--fern);
  background: rgba(90,128,64,0.15);
}

/* Review section */
.review-section { margin-top: 3rem; text-align: left; }

.review-heading {
  font-family: 'Cinzel', serif;
  font-size: 1.1rem;
  color: var(--text-secondary);
  letter-spacing: 2px;
  margin-bottom: 1rem;
  padding-bottom: 0.5rem;
  border-bottom: 1px solid var(--border-subtle);
}

.review-item {
  background: var(--forest-dark);
  border-left: 3px solid var(--border-subtle);
  border-radius: 0 6px 6px 0;
  padding: 0.9rem 1rem;
  margin-bottom: 0.75rem;
  font-size: 0.95rem;
}

.review-item.was-correct { border-left-color: var(--correct-border); }
.review-item.was-wrong   { border-left-color: var(--wrong-border); }

.review-q {
  color: var(--text-primary);
  margin-bottom: 0.3rem;
  font-weight: 600;
}

.review-exp {
  color: var(--text-secondary);
  font-size: 0.9rem;
  font-style: italic;
  line-height: 1.6;
}

/* ── LIVE REGION (ADA) ───────────────────────── */
.sr-only {
  position: absolute;
  width: 1px; height: 1px;
  padding: 0; margin: -1px;
  overflow: hidden;
  clip: rect(0,0,0,0);
  white-space: nowrap;
  border: 0;
}

/* ── RESPONSIVE ──────────────────────────────── */
@media (max-width: 560px) {
  .stat-grid { grid-template-columns: repeat(3, 1fr); gap: 0.5rem; }
  .q-card { padding: 1.4rem 1.2rem; }
  .choice-btn { padding: 0.8rem 1rem; font-size: 1rem; }
  .key-hint-bar { display: none; }
  h1.game-title { font-size: 2rem; }
}

/* ── DECORATIVE DIVIDER ──────────────────────── */
.divider {
  display: flex;
  align-items: center;
  gap: 1rem;
  margin: 2rem 0;
  color: var(--text-muted);
  font-size: 0.7rem;
  font-family: 'Source Code Pro', monospace;
  letter-spacing: 2px;
}
.divider::before, .divider::after {
  content: '';
  flex: 1;
  height: 1px;
  background: linear-gradient(90deg, transparent, var(--border-subtle), transparent);
}
</style>
</head>
<body>

