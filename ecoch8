<script>
/* ═══════════════════════════════════════
   QUESTION BANK — Chapter 18
   Community Dynamics (20 questions)
═══════════════════════════════════════ */
const ALL_QUESTIONS = [
  // ── SUCCESSION FUNDAMENTALS ──────────
  {
    topic: "Succession",
    q: "What term describes the full ordered sequence of community types that develops from disturbance to a mature state?",
    choices: ["Seral stage","Biome","Sere","Chronosequence"],
    ans: 2,
    diff: "core",
    explain: "A sere is the complete sequence; each individual step along that path is called a seral stage. Succession is the process; the sere is the whole trajectory."
  },
  {
    topic: "Primary Succession",
    q: "Primary succession begins on substrates WITH no soil — such as fresh lava flows or glacial till. What term describes the first species to colonize?",
    choices: ["Climax species","Inhibitors","Pioneer species","Shade-tolerant relics"],
    ans: 2,
    diff: "core",
    explain: "Pioneer species tolerate harsh extremes (drought, heat, nutrient poverty) and are first to colonize bare substrate. They begin building soil and organic matter."
  },
  {
    topic: "Secondary Succession",
    q: "Secondary succession differs from primary succession primarily because:",
    choices: [
      "It only occurs underwater",
      "Soil and a seed bank are already present when disturbance ends",
      "It always takes longer than primary succession",
      "It never produces a forest"
    ],
    ans: 1,
    diff: "core",
    explain: "Secondary succession begins where soil and biological legacies (seeds, rootstocks, microbes) remain, so it typically proceeds faster than primary succession."
  },
  {
    topic: "Succession Mechanisms",
    q: "In the facilitation model of succession, early species:",
    choices: [
      "Suppress later species through shade and allelopathy",
      "Are unaffected by later colonizers",
      "Improve conditions (soil, nutrients) that benefit later species",
      "Persist indefinitely, blocking community change"
    ],
    ans: 2,
    diff: "core",
    explain: "Facilitation means early arrivals make the site more hospitable — e.g., nitrogen-fixing plants enriching soil — clearing the path for later successional species."
  },
  {
    topic: "Succession Mechanisms",
    q: "Which successional mechanism produces 'priority effects' — outcomes that depend heavily on which species arrives first?",
    choices: ["Tolerance","Facilitation","Autogenic change","Inhibition"],
    ans: 3,
    diff: "hard",
    explain: "Inhibition: established species actively prevent newcomers from gaining ground. Whoever colonizes first can hold the site, so arrival order determines outcomes."
  },
  {
    topic: "Succession Mechanisms",
    q: "The tolerance model predicts that late-successional species eventually dominate because they:",
    choices: [
      "Arrive first and suppress all others",
      "Receive active help from early species",
      "Can endure low resources and outlast early colonizers competitively",
      "Reproduce faster than any other species"
    ],
    ans: 2,
    diff: "hard",
    explain: "In the tolerance model, later species are unaffected (neutral) by early colonizers but simply outlast them by tolerating low light, low nutrients, or other stresses."
  },
  {
    topic: "Autogenic Change",
    q: "Autogenic changes during succession are caused by:",
    choices: [
      "External forces like floods and climate shifts",
      "The organisms in the community themselves",
      "Plate tectonic movement",
      "Government land-use policies"
    ],
    ans: 1,
    diff: "core",
    explain: "Autogenic = self-generated. As organisms grow, they alter shade, litter depth, soil chemistry, and moisture — reshaping the environment and filtering which species persist."
  },
  // ── DIVERSITY & RESOURCES ────────────
  {
    topic: "Diversity Patterns",
    q: "During succession, species diversity typically follows which pattern?",
    choices: [
      "Rises steadily and plateaus permanently at a maximum",
      "Decreases from start to finish",
      "Rises, peaks at mid-succession, then declines as competitive dominants take over",
      "Remains constant throughout"
    ],
    ans: 2,
    diff: "core",
    explain: "Early succession offers many open niches; mid-succession has peak habitat heterogeneity. Late stages are dominated by a few shade-tolerant species, reducing diversity."
  },
  {
    topic: "Heterotrophs in Succession",
    q: "Why do herbivore and predator communities also change during plant succession?",
    choices: [
      "Animals drive plant succession, not the reverse",
      "Changing plant structure (cover, height, composition) alters food and habitat for animals",
      "Animals are unaffected by vegetation changes",
      "Only decomposers respond to succession"
    ],
    ans: 1,
    diff: "core",
    explain: "More shrub cover brings different nesting birds; taller canopy supports different insects and bats. Heterotrophs track the structural and compositional changes in vegetation."
  },
  {
    topic: "Allogenic Change",
    q: "Allogenic drivers of community change are EXTERNAL forces. Which is an example?",
    choices: [
      "Tree shading reducing understory light",
      "Litter accumulation altering soil pH",
      "A seasonal flood pulse resetting riparian vegetation",
      "Mycorrhizal networks facilitating seedling establishment"
    ],
    ans: 2,
    diff: "hard",
    explain: "Allogenic = externally driven. Floods, droughts, glacial retreat, and sea-level change are allogenic — unlike autogenic drivers generated by the community itself."
  },
  // ── DISTURBANCE & STABILITY ──────────
  {
    topic: "Stability & Resilience",
    q: "Resilience in an ecological community is BEST defined as:",
    choices: [
      "The tendency to resist any change at all",
      "The diversity of species present",
      "The speed and degree to which a community recovers after disturbance",
      "The maximum biomass a site can support"
    ],
    ans: 2,
    diff: "core",
    explain: "Resilience is about recovery capacity — how quickly and completely a community bounces back. Stability is resistance to change; these are distinct concepts."
  },
  {
    topic: "Alternate Stable States",
    q: "Alternate stable states exist when a community:",
    choices: [
      "Follows only one possible successional pathway",
      "Can persist in multiple self-reinforcing configurations under the same environment",
      "Always returns to the same climax community after disturbance",
      "Has equal numbers of R- and K-selected species"
    ],
    ans: 1,
    diff: "hard",
    explain: "Alternate stable states: the same environment can maintain different community types, each reinforcing itself. Crossing a threshold is required to shift between states."
  },
  // ── SPECIES TRAITS ───────────────────
  {
    topic: "Life History Traits",
    q: "Which set of traits best describes an R-selected (early successional) plant species?",
    choices: [
      "Slow growth, high shade tolerance, few large seeds, long lifespan",
      "Fast growth, low shade tolerance, many small seeds, short lifespan",
      "Moderate growth, medium seeds, medium lifespan",
      "Slow growth, low shade tolerance, many large seeds"
    ],
    ans: 1,
    diff: "core",
    explain: "R-selected species invest in rapid reproduction and dispersal — fast growth, many small seeds, short lives. They thrive in open, disturbed, unpredictable habitats."
  },
  {
    topic: "Life History Traits",
    q: "A late-successional hardwood tree (K-selected) is expected to have:",
    choices: [
      "High shade tolerance, slow growth, few large seeds, long lifespan",
      "Low shade tolerance, fast growth, many small seeds",
      "Annual life cycle, wind-dispersed seeds",
      "No mycorrhizal associations"
    ],
    ans: 0,
    diff: "core",
    explain: "K-selected species are built for stable, competitive environments: shade tolerance lets them establish under closed canopy, and large seeds provide seedling resources."
  },
  // ── CASE STUDIES ─────────────────────
  {
    topic: "Case Study",
    q: "At Glacier Bay, Alaska, which organisms are among the FIRST to colonize after glacial retreat?",
    choices: [
      "Spruce and hemlock trees",
      "Annual grasses and oaks",
      "Lichens and nitrogen-fixing plants",
      "Large mammals"
    ],
    ans: 2,
    diff: "core",
    explain: "Lichens and N-fixing plants (like alder) pioneer Glacier Bay's bare glacial till — tolerating extreme conditions and beginning soil formation before shrubs and trees arrive."
  },
  {
    topic: "Case Study",
    q: "In kelp forest recovery (NE Pacific), what event typically triggers re-establishment of kelp?",
    choices: [
      "Increased water temperature",
      "Sea otter immigration reducing sea urchin overgrazing",
      "Mass coral bleaching",
      "Changes in ocean salinity"
    ],
    ans: 1,
    diff: "hard",
    explain: "Sea otters prey on urchins; when urchin grazing is controlled, kelp can recolonize. This trophic cascade demonstrates how grazers can lock systems in alternative states."
  },
  // ── HUMAN IMPACT & MANAGEMENT ────────
  {
    topic: "Human Impact",
    q: "Fire suppression policies in fire-adapted ecosystems most directly lead to:",
    choices: [
      "Increased species diversity",
      "Promotion of early-successional pioneer species",
      "Accumulation of fuels and dominance by late-successional species",
      "Faster recovery after disturbance"
    ],
    ans: 2,
    diff: "hard",
    explain: "Fire suppression removes a key disturbance, allowing fuel loads to build and late-successional species to dominate — often increasing catastrophic fire risk over time."
  },
  {
    topic: "Human Impact",
    q: "Invasive exotic species can alter successional trajectories primarily through which mechanism?",
    choices: [
      "Facilitation only — they always help native species",
      "Inhibition — locking the community in an undesired state via competitive suppression",
      "Tolerance — they simply coexist without effect",
      "Autogenic stabilization"
    ],
    ans: 1,
    diff: "hard",
    explain: "Invasives often inhibit native regeneration through allelopathy, dense cover, or resource pre-emption, preventing recovery and holding the system in an invaded state."
  },
  {
    topic: "Restoration",
    q: "Which restoration strategy BEST uses facilitation to accelerate succession?",
    choices: [
      "Removing all vegetation and starting bare",
      "Planting shade-intolerant exotic species",
      "Planting nurse species that improve soil and microclimate for target species",
      "Applying broad-spectrum herbicides"
    ],
    ans: 2,
    diff: "core",
    explain: "Nurse species (facilitators) stabilize soil, add nitrogen, and buffer microclimate — making the site hospitable for target late-successional species to establish faster."
  },
  {
    topic: "Land-Use History",
    q: "Why do ecologists say 'today's community reflects its land-use history'?",
    choices: [
      "Communities are completely reset with each disturbance event",
      "Past logging, farming, and fire policy set starting conditions and shaped successional pathways that persist for decades",
      "Only climate determines present community composition",
      "Land-use history only matters within a single season"
    ],
    ans: 1,
    diff: "core",
    explain: "Legacies of farming, logging, and fire suppression persist in seed banks, soil structure, and species composition — shaping community dynamics for decades to centuries."
  }
];

// Difficulty pools
const POOLS = {
  all:  ALL_QUESTIONS,
  core: ALL_QUESTIONS.filter(q => q.diff === 'core'),
  hard: ALL_QUESTIONS.filter(q => q.diff === 'hard' || q.diff === 'core').slice(0,10)
};

/* ═══════════════════════════════════════
   GAME STATE
═══════════════════════════════════════ */
let currentDiff   = 'all';
let questions     = [];
let qIndex        = 0;
let score         = 0;
let correctCount  = 0;
let wrongCount    = 0;
let answered      = false;
let history       = []; // {correct, question, explain}

/* ═══════════════════════════════════════
   HELPERS
═══════════════════════════════════════ */
function shuffle(arr) {
  const a = [...arr];
  for (let i = a.length - 1; i > 0; i--) {
    const j = Math.floor(Math.random() * (i + 1));
    [a[i], a[j]] = [a[j], a[i]];
  }
  return a;
}

function announce(msg, assertive = false) {
  const el = document.getElementById(assertive ? 'live-region-assertive' : 'live-region');
  el.textContent = '';
  requestAnimationFrame(() => { el.textContent = msg; });
}

function showScreen(id) {
  document.querySelectorAll('.screen').forEach(s => s.classList.remove('active'));
  document.getElementById(id).classList.add('active');
}

/* ═══════════════════════════════════════
   DIFFICULTY
═══════════════════════════════════════ */
function setDiff(btn) {
  document.querySelectorAll('.diff-btn').forEach(b => {
    b.classList.remove('selected');
    b.setAttribute('aria-pressed', 'false');
  });
  btn.classList.add('selected');
  btn.setAttribute('aria-pressed', 'true');
  currentDiff = btn.dataset.diff;
}

/* ═══════════════════════════════════════
   START / RESTART
═══════════════════════════════════════ */
function startGame() {
  questions    = shuffle(POOLS[currentDiff]);
  qIndex       = 0;
  score        = 0;
  correctCount = 0;
  wrongCount   = 0;
  history      = [];
  showScreen('quiz-screen');
  renderQuestion();
  announce('Quiz started. Question 1.');
}

function replayGame() { startGame(); }

function goMenu() {
  showScreen('title-screen');
  announce('Returned to main menu.');
}

/* ═══════════════════════════════════════
   RENDER QUESTION
═══════════════════════════════════════ */
function renderQuestion() {
  const q     = questions[qIndex];
  const total = questions.length;
  answered    = false;

  // HUD
  document.getElementById('score-val').textContent   = score;
  document.getElementById('q-num-display').textContent = `Q ${qIndex + 1} / ${total}`;
  document.getElementById('q-num-display').setAttribute('aria-label', `Question ${qIndex + 1} of ${total}`);
  document.getElementById('q-topic').textContent      = q.topic;

  const pct = (qIndex / total) * 100;
  document.getElementById('progress-fill').style.width = pct + '%';
  document.getElementById('progress-text').textContent  = `${qIndex} / ${total}`;
  document.getElementById('progress-track').setAttribute('aria-valuenow', qIndex);
  document.getElementById('progress-track').setAttribute('aria-valuemax', total);

  // Question text
  const qEl = document.getElementById('q-heading');
  qEl.textContent = q.q;

  // Choices
  const container = document.getElementById('choices-container');
  container.innerHTML = '';
  const letters = ['A','B','C','D'];

  q.choices.forEach((choice, i) => {
    const btn = document.createElement('button');
    btn.className     = 'choice-btn';
    btn.role          = 'listitem';
    btn.dataset.index = i;
    btn.setAttribute('aria-label', `Option ${letters[i]}: ${choice}`);

    btn.innerHTML = `
      <span class="choice-letter" aria-hidden="true">${letters[i]}</span>
      <span class="choice-text">${choice}</span>
      <span class="choice-key-hint" aria-hidden="true">${i+1}</span>
    `;
    btn.addEventListener('click', () => selectAnswer(i));
    container.appendChild(btn);
  });

  // Feedback + next
  const fb = document.getElementById('feedback-panel');
  fb.className       = 'feedback-panel';
  fb.textContent     = '';
  const nextBtn      = document.getElementById('btn-next');
  nextBtn.style.display = 'none';

  // Focus question for screen readers
  requestAnimationFrame(() => qEl.focus());
}

/* ═══════════════════════════════════════
   ANSWER SELECTION
═══════════════════════════════════════ */
function selectAnswer(chosen) {
  if (answered) return;
  answered = true;

  const q         = questions[qIndex];
  const isCorrect = chosen === q.ans;
  const letters   = ['A','B','C','D'];
  const buttons   = document.querySelectorAll('.choice-btn');

  buttons.forEach((btn, i) => {
    btn.disabled = true;
    if (i === q.ans)                  btn.classList.add('correct');
    else if (i === chosen && !isCorrect) btn.classList.add('wrong');
  });

  const fb = document.getElementById('feedback-panel');
  if (isCorrect) {
    score        += 10;
    correctCount++;
    fb.className  = 'feedback-panel correct';
    fb.innerHTML  = `<span class="feedback-icon" aria-hidden="true">✅</span><strong>Correct!</strong> ${q.explain}`;
    announce(`Correct! ${q.explain}`);
    document.getElementById('score-val').textContent = score;
  } else {
    wrongCount++;
    fb.className = 'feedback-panel wrong';
    fb.innerHTML = `<span class="feedback-icon" aria-hidden="true">❌</span><strong>Not quite.</strong> The answer is <strong>${letters[q.ans]}: ${q.choices[q.ans]}</strong>. ${q.explain}`;
    announce(`Incorrect. The correct answer is ${letters[q.ans]}: ${q.choices[q.ans]}. ${q.explain}`);
  }

  history.push({ correct: isCorrect, q: q.q, chosen: q.choices[chosen], correctAns: q.choices[q.ans], explain: q.explain });

  const nextBtn = document.getElementById('btn-next');
  nextBtn.style.display = 'block';
  nextBtn.focus();
}

/* ═══════════════════════════════════════
   NEXT QUESTION
═══════════════════════════════════════ */
function nextQuestion() {
  qIndex++;
  if (qIndex >= questions.length) {
    showResults();
  } else {
    renderQuestion();
    announce(`Question ${qIndex + 1} of ${questions.length}.`);
  }
}

/* ═══════════════════════════════════════
   RESULTS
═══════════════════════════════════════ */
function showResults() {
  const total = questions.length;
  const pct   = Math.round((correctCount / total) * 100);

  let heading, emoji, message, cls;
  if (pct >= 90)      { heading = 'Outstanding Ecologist'; emoji = '🌲'; message = "Exceptional! You've mastered Community Dynamics — succession, resilience, and all mechanisms. The forest holds no secrets from you."; cls = 'excellent'; }
  else if (pct >= 75) { heading = 'Seasoned Field Naturalist'; emoji = '🌿'; message = "Great work! You understand the core dynamics well. Revisit disturbance mechanisms and alternate stable states to reach mastery."; cls = 'great'; }
  else if (pct >= 55) { heading = 'Apprentice Explorer'; emoji = '🍂'; message = "Solid foundation! Review primary vs. secondary succession and the facilitation/inhibition/tolerance models — you're close."; cls = 'good'; }
  else                { heading = 'Back to the Field Notes'; emoji = '📖'; message = "Don't be discouraged — community dynamics is complex! Revisit Chapter 18, focus on succession mechanisms and diversity patterns, then try again."; cls = 'study'; }

  document.getElementById('result-emblem').textContent   = emoji;
  const rh = document.getElementById('result-heading');
  rh.textContent  = heading;
  rh.className    = `result-heading ${cls}`;
  document.getElementById('result-score').textContent    = `${correctCount} / ${total}`;
  document.getElementById('stat-correct').textContent    = correctCount;
  document.getElementById('stat-wrong').textContent      = wrongCount;
  document.getElementById('stat-pct').textContent        = `${pct}%`;
  document.getElementById('result-message').textContent  = message;

  // Review list
  const reviewList = document.getElementById('review-list');
  reviewList.innerHTML = '';
  history.forEach((item, i) => {
    const div = document.createElement('div');
    div.className = `review-item ${item.correct ? 'was-correct' : 'was-wrong'}`;
    div.setAttribute('aria-label', `Question ${i + 1}: ${item.correct ? 'Correct' : 'Incorrect'}`);
    div.innerHTML = `
      <div class="review-q">${item.correct ? '✅' : '❌'} Q${i + 1}: ${item.q}</div>
      <div class="review-exp">${item.correct ? '' : `Your answer: <em>${item.chosen}</em>. Correct: <em>${item.correctAns}</em>. `}${item.explain}</div>
    `;
    reviewList.appendChild(div);
  });

  showScreen('result-screen');
  const rs = document.getElementById('result-screen');
  rs.focus();
  announce(`Quiz complete. You scored ${correctCount} out of ${total}, ${pct}% accuracy. ${heading}.`, true);
}

/* ═══════════════════════════════════════
   KEYBOARD NAVIGATION (ADA)
═══════════════════════════════════════ */
document.addEventListener('keydown', (e) => {
  // Only active on quiz screen
  if (!document.getElementById('quiz-screen').classList.contains('active')) return;

  const num = parseInt(e.key);
  if (num >= 1 && num <= 4 && !answered) {
    const buttons = document.querySelectorAll('.choice-btn');
    if (buttons[num - 1]) selectAnswer(num - 1);
    return;
  }

  if ((e.key === 'Enter' || e.key === ' ') && answered) {
    const btn = document.getElementById('btn-next');
    if (btn.style.display !== 'none') {
      e.preventDefault();
      nextQuestion();
    }
  }
});

/* ═══════════════════════════════════════
   DECORATIVE SPORES (non-interactive)
═══════════════════════════════════════ */
(function spawnSpores() {
  const bg = document.querySelector('.forest-bg');
  for (let i = 0; i < 18; i++) {
    const s   = document.createElement('div');
    s.className = 'spore';
    s.setAttribute('aria-hidden', 'true');
    const size = 2 + Math.random() * 3;
    s.style.cssText = `
      width:${size}px; height:${size}px;
      left:${Math.random()*100}%;
      bottom:${Math.random()*30}%;
      --drift:${(Math.random()-0.5)*60}px;
      animation-duration:${8 + Math.random()*14}s;
      animation-delay:${Math.random()*12}s;
    `;
    bg.appendChild(s);
  }

  // Mist bands
  for (let i = 0; i < 3; i++) {
    const m = document.createElement('div');
    m.className = 'mist-band';
    m.setAttribute('aria-hidden', 'true');
    m.style.cssText = `
      bottom:${15 + i*12}%;
      animation-duration:${20 + i*8}s;
      animation-direction:${i % 2 === 0 ? 'alternate' : 'alternate-reverse'};
      opacity:${0.4 + i * 0.15};
    `;
    document.querySelector('.forest-bg').appendChild(m);
  }
})();
</script>
